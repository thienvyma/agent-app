// Prisma Schema — Agentic Enterprise
// 16 tables, 4 enums, full relationships
// Phase 5 (Session 5) → Extended in Session 31 for full integration

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ================ ENUMS ================

enum AgentStatus {
  IDLE
  RUNNING
  ERROR
  DEPLOYING
  PAUSED_BUDGET
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  WAITING_APPROVAL
  APPROVED
  REJECTED
  COMPLETED
  FAILED
}

enum MessageType {
  DELEGATE
  REPORT
  CHAIN
  GROUP
  ALERT
  ESCALATION
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  MODIFIED
}

// ================ AUTH (S33) ================

/// User — owner/admin authentication
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("owner")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

// ================ COMPANY (S5-S6) ================

/// Company — top-level organization entity
model Company {
  id          String   @id @default(uuid())
  name        String
  description String?
  config      Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  departments Department[]

  @@map("companies")
}

/// Department — organizational unit within a company
model Department {
  id          String   @id @default(uuid())
  name        String
  description String?
  parentId    String?
  companyId   String

  parent   Department?  @relation("DeptHierarchy", fields: [parentId], references: [id])
  children Department[] @relation("DeptHierarchy")
  company  Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  agents   Agent[]

  @@map("departments")
}

// ================ AGENT (S5-S7) ================

/// Agent — AI employee with SOP, model, tools, and skills
model Agent {
  id           String      @id @default(uuid())
  name         String
  role         String
  sop          String      @db.Text
  model        String
  tools        String[]
  skills       String[]
  status       AgentStatus @default(IDLE)
  isAlwaysOn   Boolean     @default(false)
  cronSchedule String?
  departmentId String

  department       Department       @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  tasks            Task[]
  toolPermissions  ToolPermission[]
  auditLogs        AuditLog[]
  sentMessages     Message[]        @relation("MessageFrom")
  receivedMessages Message[]        @relation("MessageTo")
  costEntries      CostEntry[]
  sessions         AgentSession[]
  conversations    Conversation[]

  @@map("agents")
}

/// AgentSession — tracks OpenClaw sessions (S7)
model AgentSession {
  id         String    @id @default(uuid())
  agentId    String
  sessionKey String    @unique
  status     String    @default("active")
  startedAt  DateTime  @default(now())
  endedAt    DateTime?

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@map("agent_sessions")
}

// ================ TASK (S9, S15) ================

/// Task — work item assigned to an agent
model Task {
  id           String     @id @default(uuid())
  description  String     @db.Text
  status       TaskStatus @default(PENDING)
  priority     Int        @default(5)
  parentTaskId String?
  assignedToId String?
  result       String?    @db.Text
  errorLog     String?    @db.Text
  retryCount   Int        @default(0)
  tokenUsage   Int        @default(0)
  createdAt    DateTime   @default(now())
  completedAt  DateTime?

  parentTask      Task?            @relation("TaskDecomposition", fields: [parentTaskId], references: [id])
  subTasks        Task[]           @relation("TaskDecomposition")
  assignedTo      Agent?           @relation(fields: [assignedToId], references: [id], onDelete: SetNull)
  approvalRequest ApprovalRequest?
  correctionLog   CorrectionLog?

  @@map("tasks")
}

/// ApprovalRequest — HITL approval workflow (S15)
model ApprovalRequest {
  id            String         @id @default(uuid())
  taskId        String         @unique
  status        ApprovalStatus @default(PENDING)
  policy        String
  reason        String
  ownerResponse String?
  telegramMsgId String?
  createdAt     DateTime       @default(now())
  resolvedAt    DateTime?

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("approval_requests")
}

// ================ MEMORY (S10-S12) ================

/// Conversation — chat session between user and agent
model Conversation {
  id        String        @id @default(uuid())
  agentId   String
  summary   String?
  createdAt DateTime      @default(now())

  agent    Agent          @relation(fields: [agentId], references: [id], onDelete: Cascade)
  messages ChatMessage[]

  @@map("conversations")
}

/// ChatMessage — individual message in a conversation
model ChatMessage {
  id             String       @id @default(uuid())
  conversationId String
  role           String
  content        String       @db.Text
  tokens         Int?
  createdAt      DateTime     @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@map("chat_messages")
}

// ================ COMMUNICATION (S13-S14) ================

/// Message — inter-agent communication
model Message {
  id          String      @id @default(uuid())
  fromAgentId String
  toAgentId   String
  content     String      @db.Text
  type        MessageType
  metadata    Json?
  createdAt   DateTime    @default(now())

  fromAgent Agent @relation("MessageFrom", fields: [fromAgentId], references: [id], onDelete: Cascade)
  toAgent   Agent @relation("MessageTo", fields: [toAgentId], references: [id], onDelete: Cascade)

  @@map("messages")
}

/// Trigger — event triggers for automation (S14)
model Trigger {
  id        String   @id @default(uuid())
  name      String
  type      String
  config    Json
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("triggers")
}

// ================ COST (S17-S18) ================

/// CostEntry — token usage per agent per request
model CostEntry {
  id        String   @id @default(uuid())
  agentId   String
  tokens    Int
  costUsd   Float
  model     String
  taskDesc  String?
  createdAt DateTime @default(now())

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@map("cost_entries")
}

/// Budget — daily budget limits
model Budget {
  id           String @id @default(uuid())
  dailyLimit   Float
  warningPct   Int    @default(80)
  currentSpent Float  @default(0)
  date         String @unique

  @@map("budgets")
}

// ================ TOOLS (S8) ================

/// ToolPermission — controls which tools each agent can use
model ToolPermission {
  id        String   @id @default(uuid())
  agentId   String
  toolName  String
  granted   Boolean  @default(true)
  grantedBy String
  createdAt DateTime @default(now())

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([agentId, toolName])
  @@map("tool_permissions")
}

// ================ AUDIT & LEARNING (S19, S26) ================

/// AuditLog — tracks all agent actions
model AuditLog {
  id        String   @id @default(uuid())
  agentId   String
  action    String
  details   Json
  timestamp DateTime @default(now())

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@map("audit_logs")
}

/// CorrectionLog — owner corrections for self-learning (S26)
model CorrectionLog {
  id            String   @id @default(uuid())
  taskId        String   @unique
  agentId       String
  context       String   @db.Text
  wrongOutput   String   @db.Text
  correction    String   @db.Text
  ruleExtracted String   @db.Text
  vectorId      String?
  createdAt     DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("correction_logs")
}

/// ActivityLog — realtime system events (S19)
model ActivityLog {
  id        String   @id @default(uuid())
  event     String
  data      Json?
  source    String?
  createdAt DateTime @default(now())

  @@map("activity_logs")
}

// ================ SCHEDULING (S29) ================

/// ScheduledJob — cron jobs for agents
model ScheduledJob {
  id             String    @id @default(uuid())
  name           String
  cronExpression String
  agentId        String
  taskTemplate   String    @db.Text
  enabled        Boolean   @default(true)
  lastRun        DateTime?
  createdAt      DateTime  @default(now())

  @@map("scheduled_jobs")
}

// ================ TENANT (S30) ================

/// Tenant — multi-tenant support
model Tenant {
  id              String   @id @default(uuid())
  name            String
  slug            String   @unique
  plan            String   @default("trial")
  maxAgents       Int      @default(2)
  maxTokensPerDay Int      @default(10000)
  status          String   @default("trial")
  createdAt       DateTime @default(now())

  @@map("tenants")
}

