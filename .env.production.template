# ==========================================
# AGENTIC ENTERPRISE - Environment Variables
# ==========================================
# Copy file nay thanh .env:
#   cp .env.production.template .env
# Sau do dien cac gia tri ben duoi.
# ==========================================

# --- Database ---
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/agentic
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=agentic

# --- Redis ---
REDIS_URL=redis://redis:6379

# --- AI Engine ---
# Neu Ollama chay trong Docker:
OLLAMA_URL=http://ollama:11434
# Neu Ollama chay tren LAN (VD: PC khac):
# OLLAMA_URL=http://192.168.1.35:8080

# --- OpenClaw Gateway ---
OPENCLAW_GATEWAY_URL=http://openclaw:18789

# --- LightRAG ---
LIGHTRAG_URL=http://lightrag:9621

# --- Authentication ---
# Tao bang: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET=THAY_BANG_RANDOM_STRING_DAI_64_KY_TU
NEXTAUTH_URL=http://localhost:3000

# --- Telegram Bot ---
# Buoc 1: Mo Telegram, tim @BotFather
# Buoc 2: /newbot → dat ten → nhan TOKEN
TELEGRAM_BOT_TOKEN=

# Buoc 1: Mo Telegram, tim @userinfobot
# Buoc 2: /start → nhan CHAT ID (so)
TELEGRAM_OWNER_CHAT_ID=

# --- Budget ---
DEFAULT_DAILY_BUDGET=100000
BUDGET_WARNING_PERCENT=80
